# Supabase + Prisma (Dashboard > Connect > Prisma). Encode @ and # as %40 and %23.
# REGION must match Project Settings > General (e.g. London = eu-west-2, Frankfurt = eu-central-1, not always eu-west-1).
# Run Prisma from packages/db: `npm run db:push` — uses this file explicitly and avoids wrong-folder .env.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

PORT_API=4000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Telegram (apps/scraper — see apps/scraper/README.md)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNELS=
TELEGRAM_FETCH_LIMIT=50

# Website scraper: auto-runs every 20 min while API is up (set false to disable)
WEBSITE_SCRAPER_ENABLED=true
WEBSITE_SCRAPER_INTERVAL_MS=1200000

# Website scraper (apps/scraper): providers = all | hahu | afriwork | ethiojobs | effoysira | generic
WEBSITE_JOBS_PROVIDER=all
# Optional label for generic scraper (defaults to API hostname)
WEBSITE_SCRAPER_SITE_LABEL=
HAHU_GRAPHQL_URL=https://graph.aggregator.hahu.jobs/v1/graphql
HAHU_JOBS_LIMIT=500
HAHU_JOBS_OFFSET=0
HAHU_JOB_DETAIL_URL_TEMPLATE=https://www.hahu.jobs/job/{{id}}

AFRIWORK_GRAPHQL_URL=https://api.afriworket.com/v1/graphql
AFRIWORK_JOBS_OFFSET=0
AFRIWORK_JOBS_PAGE_SIZE=20
AFRIWORK_JOBS_LIMIT=500
AFRIWORK_JOB_DETAIL_URL_TEMPLATE=https://afriworket.com/jobs/{{id}}
AFRIWORK_API_HEADERS=
AFRIWORK_HASURA_ROLE=anonymous

ETHIOJOBS_API_URL=https://api.ethiojobs.net/ethiojobs/api/job-board/jobs
ETHIOJOBS_START_PAGE=1
ETHIOJOBS_PAGE_SIZE=10
ETHIOJOBS_JOBS_LIMIT=500
ETHIOJOBS_JOB_DETAIL_URL_TEMPLATE=https://ethiojobs.net/job/{{slug}}
ETHIOJOBS_CUSTOM_HEADER=
ETHIOJOBS_API_HEADERS=

EFFOYSIRA_API_URL=https://effoysira.com/wp-json/wp/v2/posts
EFFOYSIRA_START_PAGE=1
EFFOYSIRA_PAGE_SIZE=20
EFFOYSIRA_JOBS_LIMIT=500
EFFOYSIRA_API_HEADERS=

WEBSITE_JOBS_API_URL=
WEBSITE_JOBS_LIST_PATH=
WEBSITE_JOBS_FIELD_MAP={}
WEBSITE_JOBS_DETAIL_URL_TEMPLATE=
WEBSITE_JOBS_ID_PATH=id
WEBSITE_JOBS_API_HEADERS=

TELEGRAM_BOT_TOKEN=
# Channel username (@yourchannel) or numeric channel id for outbound job posts
TELEGRAM_BOT_CHANNEL_ID=
# One-time backfill: how many recent jobs to post (npm run telegram:post-recent)
TELEGRAM_BACKFILL_LIMIT=10

# Supabase (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only service role key (keep secret)
SUPABASE_SERVICE_ROLE_KEY=
