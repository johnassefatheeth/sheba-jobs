# Supabase + Prisma (Dashboard > Connect > Prisma). Encode @ and # as %40 and %23.
# REGION must match Project Settings > General (e.g. London = eu-west-2, Frankfurt = eu-central-1, not always eu-west-1).
# Run Prisma from packages/db: `npm run db:push` — uses this file explicitly and avoids wrong-folder .env.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

PORT_API=4000
FRONTEND_URL=http://localhost:3000

# Telegram (apps/scraper — see apps/scraper/README.md)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNELS=
TELEGRAM_FETCH_LIMIT=50

# Website scraper (apps/scraper): providers = all | hahu | afriwork | generic
WEBSITE_JOBS_PROVIDER=all
HAHU_GRAPHQL_URL=https://graph.aggregator.hahu.jobs/v1/graphql
HAHU_JOBS_LIMIT=200
HAHU_JOBS_OFFSET=0
HAHU_JOB_DETAIL_URL_TEMPLATE=https://www.hahu.jobs/job/{{id}}

AFRIWORK_GRAPHQL_URL=https://api.afriworket.com/v1/graphql
AFRIWORK_JOBS_OFFSET=0
AFRIWORK_JOBS_PAGE_SIZE=20
AFRIWORK_JOBS_LIMIT=200
AFRIWORK_JOB_DETAIL_URL_TEMPLATE=https://afriworket.com/jobs/{{id}}
AFRIWORK_API_HEADERS=
AFRIWORK_HASURA_ROLE=anonymous

WEBSITE_JOBS_API_URL=
WEBSITE_JOBS_LIST_PATH=
WEBSITE_JOBS_FIELD_MAP={}
WEBSITE_JOBS_DETAIL_URL_TEMPLATE=
WEBSITE_JOBS_ID_PATH=id
WEBSITE_JOBS_API_HEADERS=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_CHANNEL_ID=

# Supabase (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only service role key (keep secret)
SUPABASE_SERVICE_ROLE_KEY=
