# Supabase + Prisma (Dashboard > Connect > Prisma). Encode @ and # as %40 and %23.
# REGION must match Project Settings > General (e.g. London = eu-west-2, Frankfurt = eu-central-1, not always eu-west-1).
# Run Prisma from packages/db: `npm run db:push` — uses this file explicitly and avoids wrong-folder .env.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

PORT_API=4000
FRONTEND_URL=http://localhost:3000

# Telegram
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNELS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_CHANNEL_ID=

# Supabase (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only service role key (keep secret)
SUPABASE_SERVICE_ROLE_KEY=
