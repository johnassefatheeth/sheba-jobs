{
  "name": "sheba-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "wrangler dev",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types cloudflare-env.d.ts"
  },
  "dependencies": {
    "@sheba/db": "file:../../packages/db",
    "@sheba/scraper": "file:../scraper",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250617.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "wrangler": "^4.101.0"
  },
  "overrides": {
    "iconv-lite": "0.6.3"
  }
}
