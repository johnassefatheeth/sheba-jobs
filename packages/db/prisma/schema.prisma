generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id         String   @id @default(cuid())
  title      String
  company    String?
  location   String?
  category   String?
  description String?
  source     String
  sourceUrl  String?
  applyUrl   String?
  postedAt   DateTime?
  createdAt  DateTime @default(now())

  @@unique([title, sourceUrl], name: "title_sourceUrl_unique")
}
