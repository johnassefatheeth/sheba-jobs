generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id          String   @id @default(cuid())
  slug        String?  @unique
  title       String
  normalizedTitle String?
  company     String?
  normalizedCompany String?
  companyLogoUrl String?
  location    String?
  normalizedLocation String?
  category    String?
  normalizedCategory String?
  posterType  String?
  jobType     String?
  experienceLevel String?
  educationLevel String?
  isRemote    Boolean  @default(false)
  isInternship Boolean @default(false)
  isExpired   Boolean  @default(false)
  expiresAt   DateTime?
  canonicalKey String?
  description String?
  /// Human-readable scrape origins, e.g. "Ethiojobs, HaHu Jobs" when merged across boards
  scrapedFrom String?
  source      String
  sourceUrl   String?
  applyUrl    String?
  postedAt    DateTime?
  telegramPostedAt DateTime?
  createdAt   DateTime @default(now())
  telegramDeliveries TelegramJobDelivery[]

  @@unique([title, sourceUrl], name: "title_sourceUrl_unique")
  @@index([canonicalKey], map: "job_canonical_key_idx")
}

model TelegramSubscriber {
  id                String   @id @default(cuid())
  telegramChatId    String   @unique
  telegramUserId    String?
  username          String?
  firstName         String?
  isActive          Boolean  @default(true)
  receiveAll        Boolean  @default(false)
  categories        String[] @default([])
  educationLevels   String[] @default([])
  experienceLevels  String[] @default([])
  jobTypes          String[] @default([])
  requireRemote     Boolean  @default(false)
  requireInternship Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deliveries        TelegramJobDelivery[]
}

model TelegramJobDelivery {
  id           String   @id @default(cuid())
  subscriberId String
  jobId        String
  deliveredAt  DateTime @default(now())
  subscriber   TelegramSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, jobId])
  @@index([jobId])
}

/// Editorial posts sent to the Telegram channel (challenges, news, etc.)
model ChannelPost {
  id                String    @id @default(cuid())
  type              String    // challenge | news
  title             String
  body              String
  buttonText        String?
  buttonUrl         String?
  imageUrl          String?
  imagePath         String?
  status            String    @default("draft") // draft | published
  telegramPostedAt  DateTime?
  telegramMessageId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([type])
}
